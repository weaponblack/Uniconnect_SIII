{
  "cli": {
    "version": ">= 18.8.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview"
    },
    "production": {
      "autoIncrement": true,
      "channel": "production"
    },
    "casa": {
      "channel": "casa",
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "http://192.168.20.203:4000"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "oficina": {
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "http://192.168.38.235:4000"
      },
      "android": {
        "buildType": "apk"
      }
    }
  },
  "submit": {
    "production": {}
  }
}